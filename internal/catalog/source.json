    {
      "id": "linux",
      "targets": [
        {
          "id": "opensuse-leap-160-amd64-netboot",
          "name": "openSUSE Leap 16.0 amd64 installer",
          "distribution": "opensuse",
          "release": "leap-16.0",
          "architecture": "amd64",
          "kind": "installer",
          "source": {
            "base_url": "https://download.opensuse.org/distribution/leap/16.0/repo/oss",
            "kernel_path": "boot/x86_64/loader/linux",
            "initrd_path": "boot/x86_64/loader/initrd",
            "cmdline": "netsetup=dhcp install={base_url} console=ttyS0"
          },
          "lifecycle": {
            "status": "supported",
            "source": "catalog"
          }
        },
        {
          "id": "archlinux-latest-amd64-netboot",
          "name": "Arch Linux latest amd64 netboot",
          "distribution": "archlinux",
          "release": "latest",
          "architecture": "amd64",
          "kind": "installer",
          "source": {
            "base_url": "https://geo.mirror.pkgbuild.com/iso/latest",
            "kernel_path": "arch/boot/x86_64/vmlinuz-linux",
            "initrd_path": "arch/boot/x86_64/initramfs-linux.img",
            "cmdline": "initrd=initramfs-linux.img archiso_http_srv={base_url}/ archisobasedir=arch cms_verify=y ip=dhcp net.ifnames=0 console=ttyS0"
          },
          "lifecycle": {
            "status": "supported",
            "source": "catalog"
          }
        },
        {
          "id": "gparted-live-1813-amd64",
          "name": "GParted Live 1.8.1-3 amd64",
          "distribution": "gparted",
          "release": "1.8.1-3",
          "architecture": "amd64",
          "kind": "tool",
          "source": {
            "base_url": "https://ftp.upjs.sk/pub/mirrors/gparted/gparted-live-stable/1.8.1-3",
            "kernel_path": "live/vmlinuz",
            "initrd_path": "live/initrd.img",
            "cmdline": "initrd=initrd.img boot=live config components union=overlay username=user noswap noeject vga=788 fetch={base_url}/live/filesystem.squashfs console=ttyS0"
          },
          "lifecycle": {
            "status": "supported",
            "source": "catalog"
          }
        },
        {
          "id": "memtest86plus-800-amd64",
